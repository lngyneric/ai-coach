# === AI-Shifu Course Creator — Environment Configuration ===
# Copy this file to .env and fill in the values.

# ─── Required ───────────────────────────────────────────
# Base URL of the AI-Shifu API (backend + cook-web)
SHIFU_BASE_URL=http://localhost:8080

# JWT token for API auth. Get it from localStorage("token") after logging in
# at SHIFU_BASE_URL/login. Token expires after ~24h.
SHIFU_TOKEN=

# ─── MDF Proxy (local dev only) ─────────────────────────
MDF_PROXY_URL=http://localhost:8801
MDF_PROXY_APP_ID=local-dev
