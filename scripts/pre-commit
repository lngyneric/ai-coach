#!/bin/sh
# Pre-commit hook: scan for hardcoded API keys and secrets
# Installed by: cp scripts/pre-commit .git/hooks/pre-commit

. git-sh-setup 2>/dev/null || true

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}🔍 Scanning for hardcoded secrets...${NC}"

# Patterns that look like real API keys (not placeholders)
PATTERNS="
sk-[A-Za-z0-9_\-]{30,}
ark-[a-f0-9\-]{36,}
nvapi-[A-Za-z0-9_\-]{20,}
ghp_[A-Za-z0-9]{36,}
AKIA[A-Z0-9]{16}
xox[bprs]-[A-Za-z0-9\-]+
AIza[A-Za-z0-9_\-]{30,}
fc_[a-f0-9]{30,}
Bearer [A-Za-z0-9_\-]{30,}
SECRET_KEY=['\"][A-Za-z0-9_\-]{20,}['\"]
VOLCENGINE_TTS_API_KEY=['\"][a-z0-9\-]{30,}['\"]
MYSQL_ROOT_PASSWORD=['\"][A-Za-z0-9_\-]+['\"]
"

# Patterns that are safe placeholders
EXCLUDE_PATTERNS="
YOUR_
sk-xxx
sk-XXXX
sk-\.\.\.
REPLACED_
\${[A-Z_]+}
ci-runtime-harness
\.example\.
\.env\.example
pre-commit
"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    echo "${GREEN}✅ No staged files to check.${NC}"
    exit 0
fi

HAS_ERRORS=0

for file in $STAGED_FILES; do
    # Skip binary/safe files
    case "$file" in
        *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot|*.pdf|*.zip|*.tar.gz|*.lock|*node_modules/*|*__pycache__/*|*.pyc|*.min.js|*.min.css|*package-lock.json|*yarn.lock|*go.sum)
            continue ;;
    esac
    case "$file" in
        *.example*|*.example.*|scripts/pre-commit|.pre-commit-config.yaml|scripts/gen_env_example.py)
            continue ;;
    esac

    FILE_CONTENT=$(git show ":${file}" 2>/dev/null || true)
    [ -z "$FILE_CONTENT" ] && continue

    for pattern in $PATTERNS; do
        MATCHES=$(echo "$FILE_CONTENT" | grep -oE "$pattern" || true)
        [ -z "$MATCHES" ] && continue

        for MATCH in $MATCHES; do
            IS_PLACEHOLDER=false
            for ex in $EXCLUDE_PATTERNS; do
                if echo "$MATCH" | grep -qE "$ex"; then
                    IS_PLACEHOLDER=true
                    break
                fi
            done
            if [ "$IS_PLACEHOLDER" = false ]; then
                echo "${RED}❌ SECURITY: Possible API key/secret in $file${NC}"
                echo "   Found: $MATCH"
                echo "   Use env vars, \${PLACEHOLDER}, or 'YOUR_...' instead."
                HAS_ERRORS=1
            fi
        done
    done
done

if [ "$HAS_ERRORS" = "1" ]; then
    echo ""
    echo "${RED}╔══════════════════════════════════════════════════╗${NC}"
    echo "${RED}║  ❌  COMMIT BLOCKED: Hardcoded secrets found!  ║${NC}"
    echo "${RED}╚══════════════════════════════════════════════════╝${NC}"
    exit 1
fi

echo "${GREEN}✅ No secrets detected.${NC}"
exit 0
