#!/bin/sh
# Pre-commit hook: scan for hardcoded API keys and secrets
# Installed by: cp scripts/pre-commit .git/hooks/pre-commit

. git-sh-setup 2>/dev/null || true

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}🔍 Scanning for hardcoded secrets...${NC}"

# Patterns that look like real API keys (not placeholders)
# Each pattern is a grep -E compatible regex
PATTERNS="
sk-[A-Za-z0-9_\-]{30,}
ark-[a-f0-9\-]{36,}
nvapi-[A-Za-z0-9_\-]{20,}
ghp_[A-Za-z0-9]{36,}
AKIA[A-Z0-9]{16}
xox[bprs]-[A-Za-z0-9\-]+
AIza[A-Za-z0-9_\-]{30,}
fc_[a-f0-9]{30,}
Bearer [A-Za-z0-9_\-]{30,}
SECRET_KEY=['\"][A-Za-z0-9_\-]{20,}['\"]
VOLCENGINE_TTS_API_KEY=['\"][a-z0-9\-]{30,}['\"]
MYSQL_ROOT_PASSWORD=['\"][A-Za-z0-9_\-]+['\"]
"

# Patterns that are safe placeholders (false positives)
EXCLUDE_PATTERNS="
YOUR_
sk-xxx
sk-XXXX
sk-\.\.\.
REPLACED_
\${[A-Z_]+}
ci-runtime-harness
\.example\.
\.env\.example
pre-commit
"

HAS_ERRORS=0

# Build exclusion args
EXCLUDE_ARGS=""
for p in $EXCLUDE_PATTERNS; do
    EXCLUDE_ARGS="$EXCLUDE_ARGS -e '$p'"
done

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    echo "${GREEN}✅ No staged files to check.${NC}"
    exit 0
fi

echo "$STAGED_FILES" | while read -r file; do
    # Skip binary files and safe directories
    case "$file" in
        *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot|*.pdf|*.zip|*.tar.gz|*.lock|*node_modules/*|*__pycache__/*|*.pyc|*.min.js|*.min.css|*package-lock.json|*yarn.lock|*go.sum)
            continue ;;
    esac

    # Skip files that are expected to have sample/placeholder keys
    case "$file" in
        *.example*|*.example.*|scripts/pre-commit|.pre-commit-config.yaml|scripts/gen_env_example.py)
            continue ;;
    esac

    for pattern in $PATTERNS; do
        MATCHES=$(git show ":${file}" 2>/dev/null | grep -oE "$pattern" || true)
        if [ -n "$MATCHES" ]; then
            for MATCH in $MATCHES; do
                IS_PLACEHOLDER=false
                for ex in $EXCLUDE_PATTERNS; do
                    if echo "$MATCH" | grep -qE "$ex"; then
                        IS_PLACEHOLDER=true
                        break
                    fi
                done
                if [ "$IS_PLACEHOLDER" = false ]; then
                    echo "${RED}❌ SECURITY: Possible API key/secret in $file${NC}"
                    echo "   Found: $MATCH"
                    echo "   Use environment variables, \${PLACEHOLDER}, or 'YOUR_...' instead."
                    HAS_ERRORS=1
                fi
            done
        fi
    done
done

# Wait for background processes
wait

if [ "$HAS_ERRORS" = "1" ]; then
    echo ""
    echo "${RED}╔══════════════════════════════════════════════════╗${NC}"
    echo "${RED}║  ❌  COMMIT BLOCKED: Hardcoded secrets found!  ║${NC}"
    echo "${RED}║  Remove them before committing.                ║${NC}"
    echo "${RED}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  ✅ Safe alternatives:"
    echo "    - Use \${VARIABLE} placeholders (injected at runtime)"
    echo "    - Store in .env file (not committed)"
    echo "    - Use 'YOUR_KEY_HERE' for documentation examples"
    exit 1
fi

echo "${GREEN}✅ No secrets detected.${NC}"
exit 0
