# ═══════════════════════════════════════════════
#  生产环境配置模板 (.env.example.prod)
#  复制为 .env 后填写实际值
#  
#  使用: cp .env.example.prod .env && vi .env
# ═══════════════════════════════════════════════

# ── LLM 模型 ─────────────────────────────────
# 火山引擎方舟 API Key（必填）
ARK_API_KEY="ark-<替换为实际密钥>"
ARK_ACCESS_KEY_ID=""
ARK_SECRET_ACCESS_KEY=""
DEFAULT_LLM_MODEL="ark/deepseek-v4-flash-260425"

# ── TTS 语音 ─────────────────────────────────
# 火山引擎 ark agent plan TTS API Key（必填）
VOLCENGINE_TTS_API_KEY="ark-<替换为实际密钥>"

# ── 登录认证 ─────────────────────────────────
# 企业 AAD 服务器地址（必填，关闭 bypass）
AAD_AUTH_URL="http://10.40.20.195:8082"
AAD_BYPASS=""

# ── 安全配置 ─────────────────────────────────
# Flask/JWT 签名密钥（必填，生产环境务必更换）
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="<替换为生成的安全密钥>"

# ── 数据库 ───────────────────────────────────
SQLALCHEMY_DATABASE_URI="mysql://root:ai-shifu@ai-shifu-mysql:3306/ai-shifu?charset=utf8mb4"

# ── Redis ────────────────────────────────────
REDIS_HOST="ai-shifu-redis"
REDIS_PORT="6379"

# ── 日志 ─────────────────────────────────────
LOG_LEVEL="warning"

# ── 登录方式（生产环境仅启用 AAD 工号登录） ──
LOGIN_METHODS_ENABLED="employee"
DEFAULT_LOGIN_METHOD="phone"

# ── OSS 存储（如有需要） ─────────────────────
ALIBABA_CLOUD_OSS_ACCESS_KEY_ID=""
ALIBABA_CLOUD_OSS_ACCESS_KEY_SECRET=""
ALIBABA_CLOUD_OSS_BUCKET=""
ALIBABA_CLOUD_OSS_ENDPOINT=""
